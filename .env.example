# ============================================================
# NC DMS Pro — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.
# ============================================================

# Supabase — Settings > API in your project dashboard
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY_HERE

# App
VITE_APP_NAME="NC AutoDealer DMS Pro"
VITE_APP_VERSION="1.0.0"

# Optional: NHTSA VIN Decode (free, no key needed — but set base URL)
VITE_NHTSA_API_BASE=https://vpic.nhtsa.dot.gov/api/vehicles

# Optional: Twilio (Phase 3 — SMS follow-ups)
# VITE_TWILIO_ACCOUNT_SID=
# VITE_TWILIO_AUTH_TOKEN=
# VITE_TWILIO_FROM_NUMBER=

# Optional: Resend (Phase 3 — Email)
# VITE_RESEND_API_KEY=
